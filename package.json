{
  "name": "Keira3",
  "version": "3.10.5-dev",
  "description": "Database Editor for AzerothCore",
  "homepage": "https://github.com/AzerothCore/Keira3",
  "author": {
    "name": "Francesco Borzi'",
    "email": "borzifrancesco@gmail.com",
    "url": "https://github.com/FrancescoBorzi"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "postinstall": "patch-package && electron-builder install-app-deps",
    "ng": "ng",
    "start": "npm-run-all -p ng:serve electron:serve",
    "build": "npm run electron:serve-tsc && nx build keira",
    "build:dev": "npm run build -- -c dev",
    "build:prod": "npm run build -- -c production",
    "ng:serve": "nx serve keira",
    "ng:serve:web": "nx serve keira -c dev-web -o",
    "electron:serve-tsc": "tsc -p tsconfig-serve.json",
    "electron:serve": "wait-on http-get://localhost:4200/ && npm run electron:serve-tsc && electron . --serve",
    "electron:local": "npm run build:prod && electron .",
    "electron:linux": "npm run build:prod && electron-builder build --linux",
    "electron:linux:ci": "npm run build:prod && electron-builder build --linux --publish=never",
    "electron:windows": "npm run build:prod && electron-builder build --windows",
    "electron:mac": "npm run build:prod && electron-builder build --mac",
    "electron:mac:ci": "npm run build:prod && electron-builder build --mac --publish=never",
    "electron:all": "npm run build:prod && electron-builder build --linux && electron-builder build --mac && electron-builder build --windows",
    "format": "prettier --config ./.prettierrc --ignore-path ./.prettierignore --no-editorconfig --write .",
    "format-staged": "pretty-quick --staged",
    "lint": "nx affected:lint --exclude='Keira3'",
    "test": "nx affected:test",
    "test-ci": "nx affected:test",
    "e2e": "playwright test -c apps/keira-e2e/playwright.config.ts apps/keira-e2e/",
    "e2e:show-trace": "playwright show-trace e2e/tracing/trace.zip",
    "version": "conventional-changelog -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
    "prepare": "husky install"
  },
  "dependencies": {
    "@acrodata/code-editor": "0.5.1",
    "@codemirror/lang-sql": "6.10.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@uiw/codemirror-theme-github": "4.25.10",
    "acorn": "8.15.0",
    "electron-settings": "4.0.4",
    "jquery": "3.7.1",
    "mysql2": "3.15.3",
    "ngx-select-ex": "19.0.5",
    "ngx-toastr": "20.0.5",
    "ngx-ui-switch": "16.1.0",
    "serialize-javascript": "7.0.6",
    "sqlite3": "5.1.7",
    "ssh2": "1.17.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.1",
    "@analogjs/vitest-angular": "2.6.1",
    "@angular-builders/custom-esbuild": "22.0.0",
    "@angular-devkit/build-angular": "22.0.3",
    "@angular-devkit/core": "22.0.3",
    "@angular-devkit/schematics": "22.0.3",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/animations": "22.0.2",
    "@angular/build": "22.0.3",
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/compiler-cli": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/language-service": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/platform-browser-dynamic": "22.0.2",
    "@angular/router": "22.0.2",
    "@fortawesome/fontawesome-free": "7.2.0",
    "@nx/angular": "23.0.0",
    "@nx/eslint": "23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/workspace": "23.0.0",
    "@playwright/test": "1.61.0",
    "@schematics/angular": "22.0.3",
    "@siemens/ngx-datatable": "22.4.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.41",
    "@swc/helpers": "0.5.23",
    "@types/electron-settings": "4.0.2",
    "@types/jquery": "3.5.34",
    "@types/jsdom": "28.0.3",
    "@types/mysql": "2.15.27",
    "@types/node": "24.13.2",
    "@types/sqlite3": "5.1.0",
    "@types/sqlstring": "2.3.2",
    "@types/ssh2": "1.15.5",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitest/coverage-v8": "4.1.9",
    "bootstrap": "5.3.8",
    "conventional-changelog-cli": "4.1.0",
    "cross-env": "10.1.0",
    "electron": "41.8.0",
    "electron-builder": "26.15.3",
    "electron-reload": "1.5.0",
    "escape-string-regexp": "5.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-playwright": "1.6.0",
    "eslint-plugin-prettier": "5.5.6",
    "highlight.js": "11.11.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "2.4.2",
    "lint-staged": "16.4.0",
    "lodash.isequal": "4.5.0",
    "ngx-bootstrap": "21.2.0",
    "ngx-clipboard": "16.0.0",
    "ngx-highlightjs": "10.0.0",
    "ngx-page-object-model": "1.2.0",
    "npm-run-all2": "9.0.2",
    "nx": "23.0.0",
    "patch-package": "8.0.1",
    "playwright": "1.61.0",
    "prettier": "3.8.4",
    "pretty-quick": "4.2.2",
    "rxjs": "7.8.2",
    "sqlstring": "2.3.3",
    "squel": "5.13.0",
    "ts-mockito": "2.6.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9",
    "wait-on": "9.0.10",
    "webdriver-manager": "13.0.2"
  },
  "optionalDependencies": {
    "@nx/nx-darwin-arm64": "23.0.0",
    "@nx/nx-darwin-x64": "23.0.0",
    "@nx/nx-linux-x64-gnu": "23.0.0",
    "@nx/nx-win32-x64-msvc": "23.0.0"
  },
  "overrides": {
    "ngx-select-ex": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    },
    "ngx-toastr": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    },
    "ngx-bootstrap": {
      "@angular/animations": "$@angular/animations",
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms"
    },
    "@nx/angular": {
      "@angular/build": "$@angular/build",
      "@angular-devkit/build-angular": "$@angular-devkit/build-angular",
      "@angular-devkit/core": "$@angular-devkit/core",
      "@angular-devkit/schematics": "$@angular-devkit/schematics",
      "@schematics/angular": "$@schematics/angular",
      "ng-packagr": "^22.0.0"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -e $GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{js,json,css,scss,ts}": [
      "npm run format-staged",
      "git add"
    ]
  }
}
